{
  "name": "avastudio",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "turbo lint -- --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "2.1.3",
    "typescript": "5.4.5",
    "@avastudio/config": "workspace:*",
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "eslint": "9.12.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3"
  },
  "prettier": "@avastudio/config/prettier",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,mjs,cjs,js,yaml,yml}": [
      "prettier --write"
    ]
  }
}
