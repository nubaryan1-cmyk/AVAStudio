{
  "name": "@avastudio/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=../../.env src/seed.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "@avastudio/config": "workspace:*",
    "eslint": "9.12.0",
    "drizzle-kit": "0.31.10",
    "@types/node": "20.16.11",
    "tsx": "4.19.1",
    "@electric-sql/pglite": "0.4.5",
    "@vitest/coverage-v8": "2.1.4",
    "vitest": "2.1.4"
  },
  "dependencies": {
    "@avastudio/shared": "workspace:*",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9"
  }
}
