# ───────────────────────────────────────────────────────────
# AVAStudio — пример переменных окружения (App-secrets, ADR-009)
# Скопируй в .env и заполни. РЕАЛЬНЫЙ .env НЕ коммитится (.gitignore).
# В проде значения приходят из Doppler (ЭТАП 15).
# ───────────────────────────────────────────────────────────

# Окружение: development | test | production
NODE_ENV=development

# --- Обязательные (ядро) ---
# Postgres (локально поднимается в Docker — TASK 3.1)
DATABASE_URL=postgresql://avastudio:avastudio@localhost:5432/avastudio
# Redis (локально в Docker — TASK 5.1)
REDIS_URL=redis://localhost:6379
# Мастер-ключ шифрования (KEK), 32 байта в base64. Сгенерировать:
#   openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=
# Секрет подписи JWT сессий (HS256). Сгенерировать: openssl rand -base64 48
AUTH_JWT_SECRET=
# Предыдущий ключ — только во время ротации (TASK 2.4), иначе пусто/не задавать
# CREDENTIALS_ENCRYPTION_KEY_PREV=

# --- Клиентские (доступны фронту, только NEXT_PUBLIC_*) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Плейсхолдеры будущих интеграций (Фаза 2, опциональны) ---
# STRIPE_SECRET_KEY=
# CRYPTO_PROVIDER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# REPLICATE_API_TOKEN=
# DUOPLUS_API_KEY=
# PROXY_PROVIDER_API_KEY=
