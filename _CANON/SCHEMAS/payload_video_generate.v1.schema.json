{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "_CANON/SCHEMAS/payload_video_generate.v1.schema.json",
  "title": "Video Generate Payload",
  "description": "Canonical payload schema for video.generate job type",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Text prompt for video generation"
    },
    "negative_prompt": {
      "type": "string",
      "maxLength": 1000
    },
    "provider": {
      "type": "string",
      "enum": ["wan", "kling", "veo"],
      "description": "Video generation provider"
    },
    "model": {
      "type": "string",
      "description": "Specific model to use"
    },
    "width": {
      "type": "integer",
      "minimum": 256,
      "maximum": 1920,
      "default": 1280
    },
    "height": {
      "type": "integer",
      "minimum": 256,
      "maximum": 1080,
      "default": 720
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 1,
      "maximum": 30,
      "default": 5
    },
    "fps": {
      "type": "integer",
      "minimum": 12,
      "maximum": 60,
      "default": 24
    },
    "seed": {
      "type": "integer"
    },
    "guidance_scale": {
      "type": "number",
      "minimum": 1,
      "maximum": 20,
      "default": 7.5
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Reference image for img2video"
    }
  },
  "required": ["prompt"],
  "additionalProperties": false
}
