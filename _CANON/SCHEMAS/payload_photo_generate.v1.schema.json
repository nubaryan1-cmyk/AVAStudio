{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "_CANON/SCHEMAS/payload_photo_generate.v1.schema.json",
  "title": "Photo Generate Payload",
  "description": "Canonical payload schema for photo.generate job type",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Text prompt for image generation"
    },
    "negative_prompt": {
      "type": "string",
      "maxLength": 1000,
      "description": "Negative prompt (what to avoid)"
    },
    "provider": {
      "type": "string",
      "enum": ["flux", "z-image", "qwen-image", "nano-banana"],
      "description": "Image generation provider"
    },
    "model": {
      "type": "string",
      "description": "Specific model to use"
    },
    "width": {
      "type": "integer",
      "minimum": 256,
      "maximum": 4096,
      "default": 1024
    },
    "height": {
      "type": "integer",
      "minimum": 256,
      "maximum": 4096,
      "default": 1024
    },
    "num_images": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "default": 1
    },
    "seed": {
      "type": "integer",
      "description": "Random seed for reproducibility"
    },
    "guidance_scale": {
      "type": "number",
      "minimum": 1,
      "maximum": 20,
      "default": 7.5
    },
    "num_inference_steps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 150,
      "default": 30
    },
    "lora_id": {
      "type": "string",
      "description": "Optional LoRA model ID to apply"
    },
    "lora_weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.8
    }
  },
  "required": ["prompt"],
  "additionalProperties": false
}
